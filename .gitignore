# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Virtual environments
.venv/
venv/
env/
ENV/

# Downloaded models / embeddings (large, fetched at runtime)
*.bin
*.vec
*.kv
*.kv.vectors.npy
gensim-data/
*.safetensors

# Distribution / packaging
build/
dist/
*.egg-info/

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# Node / frontend
node_modules/
frontend/dist/

# --- large, regenerable data (rebuild via code/model_building/run_pipeline.py) ---
# full GB encoders: we deleted these and serve the trimmed copies instead
data/text_encoder/
# intermediate training arrays (used only by model_building.py training)
data/text_embedding/
# gensim / huggingface download caches
data/**/_bert_cache/

# Keep the small committed pieces. The *.kv rules above would otherwise drop the
# trimmed encoders, so re-include the whole text_encoder_small/ folder.
!data/text_encoder_small/
!data/text_encoder_small/**
# (data/model_artifacts/ and data/raw/ aren't matched by any ignore -> tracked)
